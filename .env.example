# ============================================================================
# B-CIP / Business Card Intelligence Platform — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# ============================================================================

# --- OCR / YAPAY ZEKA ---------------------------------------------------------
# GEMINI_API_KEY: Gemini API çağrıları için gereklidir.
# AI Studio çalışma zamanında kullanıcı sırlarından otomatik enjekte eder.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OCR sağlayıcısı (adaptör mimarisi). Varsayılan: gemini
# Desteklenen: gemini | tesseract | google-vision | aws-textract | custom
OCR_PROVIDER="gemini"

# Kullanılacak Gemini modeli. Geçerli bir model kimliği olmalıdır.
GEMINI_MODEL="gemini-2.5-flash"

# --- GÜVENLİK (ÜRETİMDE ZORUNLU) ---------------------------------------------
# SESSION_SECRET: Oturum token'larını imzalamak için kullanılan gizli anahtar.
# Tanımsızsa her açılışta rastgele üretilir (tüm oturumlar restart'ta düşer).
# Üretimde uzun, rastgele bir değerle MUTLAKA ayarlayın:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=""

# ALLOW_DEMO_ROLE_SWITCH: RBAC gösterimi için arayüzden rol değiştirmeyi açar.
# ÜRETİMDE "false" YAPIN — aksi halde kullanıcılar kendi rollerini değiştirebilir.
ALLOW_DEMO_ROLE_SWITCH="true"

# DEMO_MFA_CODE: Demo MFA doğrulama kodu. Gerçek dağıtımda TOTP/WebAuthn ile
# değiştirilmelidir. Boşsa varsayılan "145399" kullanılır.
DEMO_MFA_CODE="145399"

# --- FIREBASE KALICILIK (ADMIN SDK) ------------------------------------------
# Sunucu, Firestore'a Admin SDK ile yazar (güvenlik kurallarını baypas eder;
# yetki requireAuth/requireRole'da uygulanır). Aşağıdakilerden BİRİ ayarlanmazsa
# kalıcılık devre dışı kalır ve veri yalnızca bellekte tutulur.
#
# Seçenek 1 — Inline servis hesabı JSON'u (Vercel vb. için pratik):
#   FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...", ...}'
FIREBASE_SERVICE_ACCOUNT=""
#
# Seçenek 2 — Servis hesabı JSON dosya yolu (ADC standardı):
#   GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
GOOGLE_APPLICATION_CREDENTIALS=""
#
# Seçenek 3 — GCP yönetimli ortamlarda (Cloud Run/Functions/App Engine) ADC
# otomatik kullanılır; ek değişken gerekmez. Yerelde zorlamak için:
#   FIREBASE_ADMIN_ADC="true"

# --- DAĞITIM ------------------------------------------------------------------
# APP_URL: Bu uygulamanın barındırıldığı URL (self-referans linkler için).
APP_URL="MY_APP_URL"

# NODE_ENV: production olduğunda Secure cookie + statik dist sunumu + debug kapalı.
NODE_ENV="development"
